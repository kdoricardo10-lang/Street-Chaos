; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Street Chaos"
run/main_scene="res://scenes/ui/Lobby.tscn"
config/features=PackedStringArray("4.7", "C#", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/autoloads/GameManager.cs"
NetworkManager="*res://scripts/autoloads/NetworkManager.cs"
MatchManager="*res://scripts/autoloads/MatchManager.cs"
CombatManager="*res://game/managers/CombatManager.cs"
LootManager="*res://game/managers/LootManager.cs"
AudioManager="*res://scripts/autoloads/AudioManager.cs"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=0

[dotnet]

project/assembly_name="Street"

[filesystem]

import/blender/enabled=false

[physics]

3d/physics_engine="Godot Physics"

[rendering]

rendering_device/driver.windows="d3d12"
